# ─── Application ─────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-64-char-string
APP_DEBUG=false
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── MongoDB ─────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change-me
MONGO_URI=mongodb://admin:change-me@mongodb:27017/raxus?authSource=admin
MONGO_DB_NAME=raxus

# ─── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0

# ─── JWT ─────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── LLM ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514

# ─── Credentials encryption ──────────────────────────────────
CREDENTIALS_ENCRYPTION_KEY=change-me-to-a-32-byte-base64-key

# ─── Monitoring ──────────────────────────────────────────────
METRICS_SCRAPE_INTERVAL_SECONDS=30
SLOW_QUERY_THRESHOLD_MS=1000

# ─── Grafana ─────────────────────────────────────────────────
GRAFANA_PASSWORD=change-me

# ─── Email (alertes) ─────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=raxus@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=Raxus <raxus@example.com>
